{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run build)",
      "Bash(npm run dev)",
      "Bash(npm run dev:*)",
      "Bash(npm run lint)",
      "Bash(npm run lint:*)",
      "Bash(npm test)",
      "Bash(npm run test:*)",
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npx tsc --noEmit)",
      "Bash(npx tsc --noEmit:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log)",
      "Bash(git log:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(git show)",
      "Bash(git show:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf /:*)",
      "Bash(npm publish:*)",
      "Bash(supabase db reset:*)",
      "Bash(supabase db push:*)"
    ]
  }
}
